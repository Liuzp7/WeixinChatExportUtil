{
  "extends": "./electron-builder.base.json",
  "productName": "微迹 Wetrace 完整版",
  "extraMetadata": {
    "wetraceVariant": "full"
  },
  "extraResources": [
    {
      "from": "assets/models",
      "to": "models",
      "filter": [
        "**/*.json",
        "**/*.txt",
        "**/onnx/encoder_model_quantized.onnx",
        "**/onnx/decoder_model_merged_quantized.onnx",
        "!**/.staging-cache/**",
        "!**/.gitkeep"
      ]
    }
  ],
  "win": {
    "artifactName": "Wetrace-Full-${version}.${ext}",
    "executableName": "Wetrace-Full"
  },
  "nsis": {
    "shortcutName": "微迹 Wetrace 完整版"
  }
}
